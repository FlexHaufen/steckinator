; stepper.pio
; Generates STEP pulses. CPU writes step count to TX FIFO.
; STEP pin = pin 0 (relative), DIR pin set before pushing step count.

.program stepper
.wrap_target
    pull block         ; Wait for step count from CPU
    mov x, osr         ; Load count into scratch X
loop:
    set pins, 1 [10]   ; STEP high, hold ~10 cycles
    set pins, 0 [10]   ; STEP low,  hold ~10 cycles
    jmp x-- loop       ; Decrement X, loop if not zero
.wrap